{
  "$description": "ResaleLane design tokens — monochrome dark theme. Final hi-fi values.",
  "color": {
    "bg": "#080808",
    "surface": "#111111",
    "surfaceAlt": "#151515",
    "surfaceInput": "#0A0A0A",
    "surfaceIcon": "#161616",
    "border": "#262626",
    "borderStrong": "#3A3A3A",
    "borderSubtle": "#1A1A1A",
    "text": "#FFFFFF",
    "text2": "#D4D4D4",
    "text3": "#A3A3A3",
    "textLegal": "#737373",
    "textFaint": "#525252",
    "onLight": "#080808",
    "chevronBack": "#8A8A8A",
    "chevronFront": "#FFFFFF",
    "buttonPrimaryHover": "#E6E6E6"
  },
  "font": {
    "family": "'Geist', system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif",
    "weights": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700, "black": 800 },
    "size": {
      "display": "clamp(38px, 6vw, 64px)",
      "h2": "clamp(26px, 4vw, 42px)",
      "h3": "18px",
      "body": "15px",
      "sm": "13.5px",
      "xs": "12.5px"
    },
    "letterSpacing": { "tight": "-0.04em", "snug": "-0.03em", "eyebrow": "0.16em" },
    "lineHeight": { "body": 1.6 }
  },
  "radius": { "sm": 8, "md": 10, "lg": 12, "xl": 16, "xxl": 18, "pill": 99 },
  "space": { "1": 6, "2": 10, "3": 14, "4": 18, "5": 24, "6": 32, "7": 40, "8": 64, "9": 80 },
  "shadow": {
    "card": "0 22px 48px -28px rgba(0,0,0,0.95)",
    "float": "0 40px 90px -50px rgba(0,0,0,0.90)",
    "toast": "0 16px 40px -12px rgba(0,0,0,0.60)",
    "glowBundle": "0 0 60px -30px rgba(255,255,255,0.18)"
  },
  "layout": { "maxWidth": 1200, "headerHeight": 64, "mobileBreakpoint": 820 },
  "motion": {
    "ease": "cubic-bezier(0.2, 0.7, 0.2, 1)",
    "durFast": "0.18s",
    "durBase": "0.22s",
    "durDrawer": "0.28s",
    "toastMs": 1800,
    "highlightMs": 2400
  }
}
